# Copy this file to `.env` and fill in your key.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — default is gpt-4o-mini
# OPENAI_CHAT_MODEL=gpt-4o

# Optional — used only if OpenAI returns quota / rate-limit style errors (e.g. 429)
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.0-flash

# Optional — document chunking (Phase 3)
# DOCUMENT_CHUNK_MAX_CHARS=1000
# DOCUMENT_CHUNK_OVERLAP=150

# Optional — OpenAI embedding model for FAISS (Phase 4)
# OPENAI_EMBED_MODEL=text-embedding-3-small

# RAG: how many FAISS chunks to inject into /chat (Phase 5)
# RAG_TOP_K=5

# Streamlit → FastAPI (Phase 6)
# API_BASE_URL=http://127.0.0.1:8000

# Vision (chat images + PDF figure captions) — defaults to gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# PDF_VISION_MAX_IMAGES=8
